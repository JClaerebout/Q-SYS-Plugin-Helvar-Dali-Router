	return components
end

function GetWiring(props)
	local wiring = { }
  
	return wiring
end

------------------------------ Local Functions --------------------------------
function HEXtoDEC(hex)
	hex = string.upper(hex)
	local b1 = string.byte(string.sub(hex, 1, 1))
	local b2 = string.byte(string.sub(hex, 2, 2))
  
	return( (b1<=57 and b1-48 or b1-55)*16 + (b2<=57 and b2-48 or b2-55) )
end

function ConvertColor(c)
	local t = {}
	t[1] = HEXtoDEC(string.sub(c,2,3))
	t[2] = HEXtoDEC(string.sub(c,4,5))
	t[3] = HEXtoDEC(string.sub(c,6,7))
	return t
end

function funcConnectSocket()
  socket:Connect(ip.String,port)
  print("Connecting...")
  Controls.Status.Value = 5
end 

function SendData(toSend)
  if socket.IsConnected then 
    socket:Write(toSend)
  else 
    print("Unable to send data, socket disconnected")
  end 
end 

------------------------------- Runtime Logic ---------------------------------

if Controls then
------------------------------------ Objects ----------------------------------


-------------------------------- Initialization -------------------------------
function Initialize()
	-- Do initialization stuff here

    ip = Controls.IP
    port = 50000

    socket = TcpSocket.New()

    socket.EventHandler = function( sock, evt, err )
        if evt == TcpSocket.Events.Connected then
            print("Connected.")
            Controls.Status.Value = 0
        elseif evt == TcpSocket.Events.Reconnect then
            print("Reconnecting...")
            Controls.Status.Value = 4
        elseif evt == TcpSocket.Events.Data then
            message = socket:Read(socket.BufferLength)
            print("TCP socket has data:",message )
        elseif evt == TcpSocket.Events.Closed then
            print("Connection Closed.")
            Controls.Status.Value = 4
        elseif evt == TcpSocket.Events.Error then
            print("Connection error.")
            Controls.Status.Value = 2
        elseif evt == TcpSocket.Events.Timeout then
            print("Connection Timeout.")
            Controls.Status.Value = 4
        end
    end

    funcConnectSocket()

    local incrementTimers = {}

    for btn, ctrl in pairs(Controls.Increment) do
        incrementTimers[btn] = Timer.New()
        incrementTimers[btn].EventHandler = function()
            Controls.Level[btn].Value = Controls.Level[btn].Value + 5
            local level = math.floor(Controls.Level[btn].Value)
            local group = Controls.GroupNumber[btn].String
            local cmd = ">V:1,C:13,G:" .. group .. ",B:1,L:" .. level .. "#"
            print(cmd)
            SendData(cmd)
            --socket:Write(cmd)
        end

        ctrl.EventHandler = function(ctrl)
            if ctrl.Boolean then
                print("Incrementing group "..btn)
                Controls.Level[btn].Value = Controls.Level[btn].Value + 5
                local level = math.floor(Controls.Level[btn].Value)
                local group = Controls.GroupNumber[btn].String
                local cmd = ">V:1,C:13,G:" .. group .. ",B:1,L:" .. level .. "#"
                print(cmd)
                SendData(cmd)
                --socket:Write(cmd)
                incrementTimers[btn]:Start(0.2)
            else
                incrementTimers[btn]:Stop()
            end
        end
    end

    local decrementTimers = {}

    for btn, ctrl in pairs(Controls.Decrement) do
        decrementTimers[btn] = Timer.New()
        decrementTimers[btn].EventHandler = function()
            Controls.Level[btn].Value = Controls.Level[btn].Value - 5
            local level = math.floor(Controls.Level[btn].Value)
            local group = Controls.GroupNumber[btn].String
            local cmd = ">V:1,C:13,G:" .. group .. ",B:1,L:" .. level .. "#"
            print(cmd)
            SendData(cmd)
            --socket:Write(cmd)
        end

        ctrl.EventHandler = function(ctrl)
            if ctrl.Boolean then
                Controls.Level[btn].Value = Controls.Level[btn].Value - 5
                local level = math.floor(Controls.Level[btn].Value)
                local group = Controls.GroupNumber[btn].String
                local cmd = ">V:1,C:13,G:" .. group .. ",B:1,L:" .. level .. "#"
                print(cmd)
                SendData(cmd)
                --socket:Write(cmd)
                decrementTimers[btn]:Start(0.2)
            else
                decrementTimers[btn]:Stop()
            end
        end
    end

    ip.EventHandler = funcConnectSocket

    for key,value in pairs(Controls.Level) do
        Controls.Level[key].EventHandler = function(ctrl)
            print("Group "..Controls.Level[key].Value)
            cmd = ">V:1,C:13,G:"..Controls.GroupNumber[key].String..",B:1,L:"..Controls.Level[key].Value.."#"
            print(cmd)
            SendData(cmd)
            --socket:Write(cmd)
        end 
    end
end

local canInitialize = true

-- Check Properties and other stuff for illegal values

if canInitialize then
	print("Initializing")
	Initialize()
	print("Initialization Complete")
else
	print("Not initializing")
end

-- Nothing should be done after this point

end	--if Controls 