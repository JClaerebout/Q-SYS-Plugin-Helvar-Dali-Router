------------------------- Plugin Block Name and Color -------------------------
function GetPrettyName(props)
    return PluginInfo["Name"] .. " v" .. PluginInfo["Version"]
end

function GetColor(props)
	return ConvertColor("#cccccc")
end

---------------------------------- Controls -----------------------------------
function GetControls(props)
    local ctls = { }

	if ENABLE_CODE_PIN then
		table.insert(ctls, {
            Name = "code",
            ControlType = "Text",
            Count = 1,
            PinStyle = "Input",
            UserPin = true
        })
	end

    table.insert(ctls, {
        Name = "Status",
        ControlType = "Indicator",
		IndicatorType = "Status",
        Count = 1,
        PinStyle = "Output",
        UserPin = true
    })

    table.insert(ctls, {
        Name = "IP",
        ControlType = "Text",
        DefaultValue = "0.0.0.0",
        Count = 1,
        PinStyle = "Input",
        UserPin = true
    })

    table.insert(ctls, {
        Name = "GroupNumber",
        ControlType = "Knob",
        ControlUnit = "Integer",
        Min = 0,
        Max = 65535,
        DefaultValue = 0,
        Count = props["#Groups"].Value,
        PinStyle = "Input",
        UserPin = true
    })

    table.insert(ctls, {
        Name = "Level",
        ControlType = "Knob",
        ControlUnit = "Percent",
        Count = props["#Groups"].Value,
        PinStyle = "Both",
        UserPin = true
    })

    table.insert(ctls, {
        Name = "Increment",
        ControlType = "Button",
        ButtonType = "Momentary",
        Count = props["#Groups"].Value,
        PinStyle = "Input",
        UserPin = true
    })

    table.insert(ctls, {
        Name = "Decrement",
        ControlType = "Button",
        ButtonType = "Momentary",
        Count = props["#Groups"].Value,
        PinStyle = "Input",
        UserPin = true
    })

    return ctls
end

------------------------------- Control Layout --------------------------------
function GetControlLayout(props)
	-- Uncomment the next line if you are using multiple pages
	local currentPage = props["page_index"].Value

    local layout = { }

	if ENABLE_CODE_PIN then
		layout["code"] = 
		{
			PrettyName = "Code",
			Style = "None"
		}
	end

    local graphics = { }

    table.insert(graphics, {
        Type = "GroupBox",
        Position = { 14,14 },
        Size = {391,222},
        StrokeColor = "black",
        StrokeWidth = 2,
        CornerRadius = 10,
    })

    helvarBase64Image = ""

    if currentPage == 1 then
        table.insert(graphics, {
            Type = "Label",
			Position = { 81,32 },
			Size = {257,25},
            Text = "Status",
            TextSize = 20,
            CornerRadius = 10,
        })
        table.insert(graphics, {
            Type = "Image", -- PNG,JPEG
            Image = helvarBase64Image,
            Position = {25,25},
            Size = {70,30}
        })
        table.insert(graphics, {
            Type = "Label",
			Position = { 81,121 },
			Size = {257,29},
            Text = "IP Address",
            TextSize = 20,
            CornerRadius = 10,
        })
        layout["Status"] = 
        {
            PrettyName = "Status",
            Position = { 81,68 },
            Size = { 257,43 },
            Style = "Text",
            TextFontSize = 20,
            WordWrap = true,
            IsBold = false
        }
        layout["IP"] = 
        {
            PrettyName = "IP Address",
            Position = { 81,159 },
            Size = { 257,43 },
            TextFontSize = 20,
            Style = "Text"
        }   

    elseif currentPage >= 2 then
        table.insert(graphics, {
            Type = "Label",
			Position = { 42,24 },
			Size = {128,16},
            Text = "Group Number",
            TextSize = 14,
        })
        table.insert(graphics, {
            Type = "Label",
			Position = { 154,24 },
			Size = {76,16},
            Text = "Level",
            TextSize = 14,
        })
        table.insert(graphics, {
            Type = "Label",
			Position = { 212,24 },
			Size = {104,16},
            Text = "Increment",
            TextSize = 14,
        })
        table.insert(graphics, {
            Type = "Label",
			Position = { 292,24 },
			Size = {104,16},
            Text = "Decrement",
            TextSize = 14,
        })

        local groupIndex = (currentPage - 2) * 5
        for i = 1, math.min(5, props["#Groups"].Value - groupIndex) do
            table.insert(graphics, {
                Type = "Label",
                Position = { 24,50 + (i-1)*35 },
                Size = {33,27},
                Text = tostring(groupIndex + i),
                TextSize = 14,
            })

            layout["GroupNumber " .. (groupIndex + i)] = 
            {
                PrettyName = "GroupNumber " .. (groupIndex + i),
                Position = { 80, 50 + (i-1)*35 },
                Size = { 60, 27 },
                Style = "Text",
                TextFontSize = 10,
                CornerRadius = 10,
            }

            layout["Level " .. (groupIndex + i)] = 
            {
                PrettyName = "Level " .. (groupIndex + i),
                Position = { 171, 50 + (i-1)*35 },
                Size = { 43, 27 },
                Style = "Text",
                TextFontSize = 10,
                CornerRadius = 10,
            }

            layout["Increment " .. (groupIndex + i)] = 
            {
                PrettyName = "Increment " .. (groupIndex + i),
                Position = { 243, 50 + (i-1)*35 },
                Size = { 43, 27 },
                Style = "Button",
                CornerRadius = 10,
            }

            layout["Decrement " .. (groupIndex + i)] = 
            {
                PrettyName = "Decrement " .. (groupIndex + i),
                Position = { 323, 50 + (i-1)*35 },
                Size = { 43, 27 },
                Style = "Button",
                CornerRadius = 10,
            }
        end
    end

    return layout, graphics
end

