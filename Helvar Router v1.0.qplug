-- Uncomment if you need multiple pages (tabs)
--Current page number can be retrieved in other functions as props["page_index"].Value

function GetPages(props)
    local pages = {}

    table.insert(pages, { name = "Config" })

    for i = 1, math.ceil(props["#Groups"].Value / 5) do
        table.insert(pages, { name = "Groups " .. ((i-1)*5 + 1) .. "-" .. math.min(i*5, props["#Groups"].Value) })
    end

    return pages
end

